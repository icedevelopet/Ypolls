from http.server import HTTPServer, BaseHTTPRequestHandler
import os
class AttackHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/':
            self.send_response(200)
            self.send_header('Content-type', 'text/html')
            self.end_headers()
            html = '<html><body style="background:black;color:red;text-align:center;padding:50px;font-family:monospace;"><h1>☢️ PANEL DE JORGE ☢️</h1><button style="background:red;color:white;padding:40px;font-size:30px;border-radius:20px;" onclick="location.href=\'/matar\'">💥 CREAR BOMBA 200MB 💥</button></body></html>'
            self.wfile.write(html.encode())
        elif self.path == '/matar':
            os.system("dd if=/dev/urandom of=BOMBA_NUCLEAR.bin bs=1M count=200")
            self.send_response(200)
            self.end_headers()
            self.wfile.write(b"BOMBA DETONADA. ALMACENAMIENTO SATURADO.")
print("Servidor de Jorge ACTIVO en http://localhost:8080")
HTTPServer(('localhost', 8080), AttackHandler).serve_forever()
EOF
