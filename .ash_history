cat << 'EOF' > app.py
from flask import Flask, request
from datetime import datetime
app = Flask(__name__)
visitas = []
@app.route('/')
def inicio():
    ahora = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    visitas.append({'ip': request.remote_addr, 'fecha': ahora})
    return '''<body style="background:#000;color:#0f0;font-family:monospace;padding:30px;">
    <h1>SISTEMA IA ACTIVO 🟢</h1>
    <div style="border:1px solid #0f0;padding:20px;">
        <input type="text" placeholder="Escribe a la IA..." style="background:#111;color:#0f0;border:1px solid #0f0;padding:10px;">
        <button onclick="alert('IA: Procesando...')" style="background:#0f0;color:#000;padding:10px;">ENVIAR</button>
    </div>
    <br><a href="/console" style="color:#666;">Acceder a /console</a>
    </body>'''
@app.route('/console')
def console():
    log = "<h1>LOG DE SEGURIDAD</h1><table border='1' style='width:100%;color:#0af;'>"
    log += "<tr><th>IP</th><th>FECHA Y HORA</th></tr>"
    for v in visitas:
        log += f"<tr><td>{v['ip']}</td><td>{v['fecha']}</td></tr>"
    log += "</table><br><a href='/' style='color:#0f0;'>Regresar</a>"
    return f'<body style="background:#111;color:#0af;font-family:monospace;padding:20px;">{log}</body>'
if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
EOF
