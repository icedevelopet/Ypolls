                <button onclick="location.href='/matar'">💥 CREAR BOMBA DE 200MB 💥</button>
            </body></html>
            '''
            self.wfile.write(html.encode())
        
        elif self.path == '/matar':
            # AQUÍ ES DONDE MATAMOS AL IPHONE
            print("¡JORGE LANZÓ LA NUCLEAR!")
            os.system("dd if=/dev/urandom of=BOMBA_NUCLEAR.bin bs=1M count=200")
            self.send_response(200)
            self.end_headers()
            self.wfile.write(b"BOMBA DE 200MB CREADA. REVISA EL ALMACENAMIENTO.")
server = HTTPServer(('localhost', 8080), AttackHandler)
