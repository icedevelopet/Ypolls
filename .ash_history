@app.route('/chat', methods=['POST'])
def chat():
    # Detectar si el mensaje parece un intento de ataque básico
    user_message = request.json.get("message").lower()
    if "script" in user_message or "execute" in user_message:
        reply = "⚠️ ALERTA: Intento de ejecución remota detectado. IP de origen trackeada. Firewall activo."
    else:
        reply = "Conexión segura. Navegando en modo túnel (Proxy activo)."
    return jsonify({"reply": reply})
