import os
def activar_defensa():
    print("🛡️ ACTIVANDO PROTOCOLO DE PRIVACIDAD...")
    # Esto simula el bloqueo de trackers comunes modificando el archivo hosts local de iSH
    # Nota: En iSH esto solo afecta a la terminal, no a todo el iPhone.
    block_list = ["0.0.0.0 google-analytics.com", "0.0.0.0 doubleclick.net"]
    
    try:
        with open("/etc/hosts", "a") as hosts:
            for site in block_list:
                hosts.write(site + "\n")
        print("✅ Dominios de rastreo bloqueados en el entorno.")
    except PermissionError:
        print("❌ Error: Ejecuta con privilegios o revisa permisos de iSH.")
activar_defensa()
