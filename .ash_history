import os, time, sys
def glitch_print(text, delay=0.01):
    for char in text:
        sys.stdout.write(char)
        sys.stdout.flush()
        time.sleep(delay)
    print()
def ejecutar_falso(comando):
    print("\033[1;30m" + "root@iphone8_kernel:~# " + "\033[0m", end="")
    glitch_print(comando, 0.04)
    time.sleep(0.2)
def do_attack():
    print("\n\033[1;31m[!] ALERTA: INTRUSIÓN DETECTADA - USUARIO: JORGE\033[0m")
    time.sleep(1)
    
    ejecutar_falso("systemctl stop apple-security-daemon")
    glitch_print("\033[1;31m[-] ERROR: ACCESS_DENIED... BYPASSING VIA EXPLOIT 0x882\033[0m")
    
    ejecutar_falso("rm -rf /System/Library/Caches/com.apple.kernel.objects")
    glitch_print("[*] SECRETO INDUSTRIAL: ELIMINANDO RASTROS...")
    
    ejecutar_falso("vmo_dump --force --pid=all")
    glitch_print("PAGE_FAULT IN NONPAGED_AREA... MEMORY_MANAGEMENT_ERROR")
    
    print("\n\033[1;33m>>> INICIANDO SOBRECARGA TÉRMICA DEL PROCESADOR A11 <<<\033[0m")
    glitch_print("CPU_CORE_0: 98°C - CRITICAL")
    glitch_print("CPU_CORE_1: 99°C - CRITICAL")
    
    print("\n\033[41m\033[1;37m INYECTANDO CARGA DE 200MB: BOMBA_COLAPSO.bin \033[0m")
    # Detonación real del archivo
    os.system("dd if=/dev/urandom of=BOMBA_COLAPSO.bin bs=1M count=200")
    
    print("\n\033[1;31m[KERNEL PANIC: EL SISTEMA SE HA RENDIDO]\033[0m")
    print("\033[1;31mIPHONE 8 STATUS: OFFLINE / CORRUPTED\033[0m")
from http.server import HTTPServer, BaseHTTPRequestHandler
class Handler(BaseHTTPRequestHandler):
    def log_message(self, *args): return
    def do_GET(self):
        self.send_response(200)
        self.end_headers()
        self.wfile.write(b"<html><body style='background:black;color:white;text-align:center;padding:100px;font-family:monospace;'><h1>[SISTEMA SIENDO EDITADO POR JORGE]</h1><p style='color:red;'>CUIDADO: EL KERNEL SE ESTA QUEMANDO</p></body></html>")
        do_attack()
print("Servidor de Colapso Jorge v2 ONLINE - Puerto 8080")
HTTPServer(('localhost', 8080), Handler).serve_forever()
EOF
