cat << 'EOF' > app.py
from flask import Flask, render_template_string
app = Flask(__name__)
H = '''<!DOCTYPE html><html><body style="font-family:sans-serif;text-align:center;padding:50px">
<div id="s1"><h2>ypolls</h2><p>¿Deseas continuar?</p><button onclick="s1.style.display='none';s2.style.display='block'">Sí</button></div>
<div id="s2" style="display:none"><h3>Marcas:</h3><input type="checkbox"> Amazon<br><button onclick="s2.style.display='none';s3.style.display='block'">Siguiente</button></div>
<div id="s3" style="display:none"><h2>¡Gracias!</h2><button onclick="window.location.href='https://google.com'">Salir</button></div>
</body></html>'''
@app.route('/')
def home(): return render_template_string(H)
app.run(host='0.0.0.0', port=5000)
EOF
